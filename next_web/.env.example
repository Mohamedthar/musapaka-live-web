# Supabase - Public (exposed to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase - Server-only admin key (NEVER expose to client, used by API routes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL for CORS
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Turnstile CAPTCHA
TURNSTILE_SECRET_KEY=your-turnstile-secret-key
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Cloudinary - Server-only (uploaded via /api/upload endpoint)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset

# Extra CORS origins (comma-separated, optional)
# EXTRA_CORS_ORIGINS=https://other-domain.com,https://staging.example.com
